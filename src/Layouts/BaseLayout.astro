---
const {
  title = "Class6Loaner",
  description = "Safety-first riding and road-test education for motorcycle Class 6.",
  canonicalPath = "/",
} = Astro.props;

const canonicalUrl = `https://class6loaner.com${canonicalPath}`;

// Optional city context (used to keep sponsors + links local once a visitor picks a city)
const citySlug = Astro.url.searchParams.get("city");

// Active nav highlight
const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
};

// BMB conversion CTA (dynamic based on current page)
const bmbCta = (() => {
  const p = path;

  // Default mentor CTA (home/most pages)
  const mentorCta = {
    text: "Apply as a Calgary Mentor — Spring Pilot",
    href: "https://borrowmybike.ca/mentors/start?utm_source=class6loaner&utm_medium=website&utm_campaign=calgary_pilot&utm_content=header_cta_mentor",
    audience: "mentor",
    placement: "header",
  };

  const testTakerCta = {
    text: "Sign up — be first to book this spring",
    href: "https://borrowmybike.ca/test-takers?utm_source=class6loaner&utm_medium=website&utm_campaign=calgary_pilot&utm_content=header_cta_testtaker",
    audience: "test_taker",
    placement: "header",
  };

  // Shorter CTA label for internal guide pages (prevents nav crowding)
  const mentorCtaShort = {
    text: "Start Mentor Profile",
    href: mentorCta.href,
    audience: "mentor",
    placement: "header",
  };

  const testTakerCtaShort = {
    text: "Sign up to book",
    href: testTakerCta.href,
    audience: "test_taker",
    placement: "header",
  };

  // Road-test intent
  if (p.startsWith("/road-test")) return testTakerCtaShort;

  // Mentor intent (mentor pages + anything mentor-oriented)
  if (p.startsWith("/become-a-mentor") || p.startsWith("/mentor-guide")) return mentorCtaShort;

  // Default: mentor-first (Calgary pilot)
  return mentorCta;
})();

// Helper: keep city context when navigating around the site
function withCity(p: string) {
  if (!citySlug) return p;
  if (p.startsWith("http")) return p;
  return `${p}${p.includes("?") ? "&" : "?"}city=${encodeURIComponent(citySlug)}`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JNNHTK6EJT"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', 'G-JNNHTK6EJT');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <style>
      :root {
        --bg: #f8fafc;
        --card: #ffffff;
        --ink: #0f172a;
        --muted: #475569;
        --border: #e2e8f0;
        /* Slightly wider content container to reduce “dead space” on desktop */
        --max: 1240px;

        /* Brand accent (gold) */
        --accent: #C9A227;
        --accent-ink: #0B1F3B;
        --accent-soft: rgba(201, 162, 39, 0.16);

        --shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
      }

      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.5;
        overflow-x: hidden;
      }

      /* Kill underlines globally (menu looked like one long underlined string) */
      a { color: inherit; text-decoration: none; }
      a:hover { text-decoration: none; }

      .wrap { max-width: var(--max); margin: 0 auto; padding: 18px 18px; }

      /* NAV */
      .nav {
        border-bottom: 1px solid var(--border);
        background: rgba(248,250,252,.88);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .navInner {
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }

      .brand {
        display:flex;
        align-items:center;
        gap: 10px;
        min-width: 210px;
      }

      .brand img { height: 40px; width: auto; display:block; }

      .pill {
        display:inline-flex;
        align-items:center;
        gap:8px;
        padding: 6px 10px;
        border-radius:999px;
        border:1px solid var(--border);
        background: rgba(255,255,255,.75);
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
      }

      /* Desktop links */
      .links {
        display:flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items:center;
        justify-content:center;
      }

      .links a {
        color: var(--muted);
        font-weight: 900;
        font-size: 14px;
        padding: 8px 10px;
        border-radius: 999px;
        border: 1px solid transparent;
        line-height: 1;
      }

      .links a:hover {
        color: var(--ink);
        background: rgba(255,255,255,.65);
        border-color: var(--border);
      }

      .links a.active {
        color: var(--accent-ink);
        background: var(--accent-soft);
        border-color: rgba(201, 162, 39, 0.35);
      }

      .cta {
        display:inline-flex;
        align-items:center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--card);
        font-weight: 1000;
        white-space: nowrap;
      }
      .cta:hover { border-color: #cbd5e1; }

      /* Mobile menu button (HIDDEN on desktop) */
      .menuBtn {
        display:none;
        align-items:center;
        gap:8px;
        padding: 10px 12px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,.75);
        font-weight: 1000;
        cursor: pointer;
        white-space: nowrap;
      }

      /* Mobile menu panel */
      .menuPanel {
        display:none;
        border-top: 1px solid var(--border);
        background: rgba(248,250,252,.92);
      }
      .menuPanelInner {
        display:grid;
        gap: 12px;              /* more separation */
        padding-top: 12px;
        padding-bottom: 14px;
      }
      .menuPanel a {
        display:block;          /* guarantees separation */
        font-weight: 950;
        color: var(--muted);
        padding: 12px 14px;     /* bigger tap target */
        border-radius: 14px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,.86);
        line-height: 1.15;      /* avoids “one long line” feel */
        font-size: 15px;
      }
      .menuPanel a:hover {
        color: var(--ink);
        border-color: #cbd5e1;
      }
      .menuPanel a.active {
        color: var(--accent-ink);
        background: var(--accent-soft);
        border-color: rgba(201, 162, 39, 0.35);
      }

      /* LAYOUT + COMPONENTS */
      .card { background: var(--card); border: 1px solid var(--border); border-radius: 18px; padding: 18px; box-shadow: var(--shadow); }
      .muted { color: var(--muted); }
      .grid { display:grid; gap: 14px; }

      @media (min-width: 980px) {
        .grid-2 { grid-template-columns: 1.3fr .7fr; align-items: start; }
        .grid-3 { grid-template-columns: repeat(3, 1fr); }
      }

      /* TYPOGRAPHY NORMALIZATION */
      main h1, main h2, main h3 {
        margin: 0 0 10px;
        letter-spacing: -0.01em;
      }
      main h1 { font-size: clamp(28px, 3.2vw, 40px); line-height: 1.08; }
      main h2 { font-size: clamp(20px, 2.2vw, 28px); line-height: 1.12; }
      main h3 { font-size: 18px; line-height: 1.2; }

      main p { margin: 10px 0; }
      main ul, main ol { margin: 10px 0; padding-left: 22px; }
      main li { margin: 6px 0; }

      footer { border-top: 1px solid var(--border); margin-top: 28px; }
      .tiny { font-size: 13px; color: var(--muted); }
      .tiny a { text-decoration: underline; } /* keep footer link obvious */

      /* Accordion / FAQ (native <details>) */
      details.acc {
        border: 1px solid var(--border);
        border-radius: 18px;
        background: #fff;
        box-shadow: var(--shadow);
        overflow: hidden;
      }
      details.acc + details.acc { margin-top: 10px; }
      details.acc summary {
        list-style: none;
        cursor: pointer;
        padding: 14px 14px;
        font-weight: 1000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      details.acc summary::-webkit-details-marker { display:none; }
      details.acc summary .accHint { color: var(--muted); font-weight: 800; font-size: 13px; }
      details.acc summary .accIcon { color: var(--muted); font-weight: 1000; }
      details.acc[open] summary { border-bottom: 1px solid var(--border); }
      .accBody { padding: 14px; }
      .accBody ul { margin: 10px 0 0; padding-left: 18px; }
      .accBody li { margin: 6px 0; }

      /* Subtle scroll reveal */
      .revealItem {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 420ms ease, transform 420ms ease;
      }
      .revealItem.isVisible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .revealItem { opacity: 1; transform: none; transition: none; }
      }

      /* RESPONSIVE: mobile nav becomes dropdown */
      @media (max-width: 860px) {
        .wrap { padding: 14px 14px; }

        .brand { min-width: unset; }
        .brand img { height: 34px; }

        .links { display:none; }
        .menuBtn { display:inline-flex; }

        .cta { padding: 9px 12px; }
      }
    </style>
  </head>

  <body>
    <header class="nav">
      <div class="wrap navInner">
        <a class="brand" href={withCity("/")}>
          <img src="/images/logo.png" alt="Class6Loaner logo" />
          {citySlug && <span class="pill" title="Local context is on">City mode ✓</span>}
        </a>

        <nav class="links" aria-label="Primary">
          <a class={isActive("/how-it-works") ? "active" : ""} href={withCity("/how-it-works")}>How it works</a>
          <a class={isActive("/road-test-guide") ? "active" : ""} href={withCity("/road-test-guide")}>Road test guide</a>
          <a class={isActive("/mentor-guide") ? "active" : ""} href={withCity("/mentor-guide")}>Mentor guide</a>
        </nav>

        <button class="menuBtn" type="button" aria-expanded="false" aria-controls="mobileMenu" id="menuBtn">
          Menu ▾
        </button>

        <a
          class="cta"
          href={bmbCta.href}
          rel="noopener"
          target="_blank"
          data-cta="header"
          data-audience={bmbCta.audience}
        >
          {bmbCta.text} →
        </a>
      </div>

      <div class="menuPanel" id="mobileMenu" hidden>
        <div class="wrap menuPanelInner">
          <a class={isActive("/how-it-works") ? "active" : ""} href={withCity("/how-it-works")}>How it works</a>
          <a class={isActive("/road-test-guide") ? "active" : ""} href={withCity("/road-test-guide")}>Road test guide</a>
          <a class={isActive("/mentor-guide") ? "active" : ""} href={withCity("/mentor-guide")}>Mentor guide</a>
          <a class={isActive("/become-a-mentor") ? "active" : ""} href={withCity("/become-a-mentor")}>Become a mentor</a>
          <a
            href={bmbCta.href}
            rel="noopener"
            target="_blank"
            data-cta="header"
            data-audience={bmbCta.audience}
          >
            {bmbCta.text} →
          </a>
        </div>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer>
      <div class="wrap">
        <div class="tiny" style="display:flex; gap:14px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>© {new Date().getFullYear()} Class6Loaner • Canada-born • Education + safety-first community</div>
          <div>
            Educational content only. Bookings happen on <a href="https://borrowmybike.ca" rel="noopener" target="_blank">borrowmybike.ca</a>.
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Persist "city mode" so visitors keep local context across pages
      (function () {
        try {
          const url = new URL(window.location.href);
          const city = url.searchParams.get("city");
          if (city) {
            localStorage.setItem("c6l_city", city);
          } else {
            const saved = localStorage.getItem("c6l_city");
            if (saved) {
              document.querySelectorAll('a[href^="/"]').forEach((a) => {
                const href = a.getAttribute("href");
                if (!href) return;
                if (href.includes("city=")) return;
                const joiner = href.includes("?") ? "&" : "?";
                a.setAttribute("href", href + joiner + "city=" + encodeURIComponent(saved));
              });
            }
          }
        } catch {}
      })();

      // Mobile menu toggle
      (function () {
        const btn = document.getElementById("menuBtn");
        const panel = document.getElementById("mobileMenu");
        if (!btn || !panel) return;

        function setOpen(open) {
          btn.setAttribute("aria-expanded", open ? "true" : "false");
          panel.hidden = !open;
          panel.style.display = open ? "block" : "none";
        }

        let open = false;
        setOpen(false);

        btn.addEventListener("click", () => {
          open = !open;
          setOpen(open);
        });

        panel.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", () => {
            open = false;
            setOpen(false);
          });
        });
      })();

      // Scroll reveal for cards + accordions
      (function () {
        try {
          const items = Array.from(document.querySelectorAll('.card, details.acc'));
          items.forEach((el) => el.classList.add('revealItem'));

          if ('IntersectionObserver' in window) {
            const io = new IntersectionObserver(
              (entries) => {
                entries.forEach((e) => {
                  if (e.isIntersecting) {
                    e.target.classList.add('isVisible');
                    io.unobserve(e.target);
                  }
                });
              },
              { root: null, threshold: 0.12 }
            );
            items.forEach((el) => io.observe(el));
          } else {
            items.forEach((el) => el.classList.add('isVisible'));
          }
        } catch {}
      })();

      // Accordion icon toggle
      (function () {
        try {
          document.querySelectorAll('details.acc').forEach((d) => {
            const icon = d.querySelector('.accIcon');
            if (!icon) return;
            const set = () => (icon.textContent = d.open ? '−' : '+');
            set();
            d.addEventListener('toggle', set);
          });
        } catch {}
      })();

      // === ADDED: GA4 CTA click tracking (header + home hero CTAs) ===
      (function () {
        try {
          if (typeof window.gtag !== "function") return;

          const cityMode = (function () {
            try {
              return localStorage.getItem("c6l_city") ? "on" : "off";
            } catch {
              return "off";
            }
          })();

          document.addEventListener("click", function (e) {
            const target = e.target;
            if (!(target instanceof Element)) return;

            const a = target.closest("a");
            if (!a) return;

            // Track only our CTAs (header + hero)
            const ctaPlacement = a.getAttribute("data-cta");
            const audience = a.getAttribute("data-audience");
            if (!ctaPlacement || !audience) return;

            const href = a.getAttribute("href") || "";

            window.gtag("event", "cta_click", {
              placement: ctaPlacement,
              audience,
              href,
              city_mode: cityMode,
              page_path: window.location.pathname,
            });
          });
        } catch {}
      })();
    </script>
  </body>
</html>
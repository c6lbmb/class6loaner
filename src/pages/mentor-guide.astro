---
import BaseLayout from "../layouts/BaseLayout.astro";
import LocationGate from "../components/LocationGate.astro";

const title = 'Mentor guide — calm, structured, safety-first support | Class6Loaner';
const description = 'Detailed mentor expectations for supporting a Class 6 road test: no rentals, no training, calm communication, safe handoff, and professional test-day support.';
const canonicalPath = '/mentor-guide';
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <LocationGate
    targetBasePath={canonicalPath}
    title="Choose your location"
    body={'To show the correct mentor guide for your area, please choose your location.'}
    note="Don't see your city? Choose the closest location for now and email support@borrowmybike.ca and we'll add it."
  />
</BaseLayout>

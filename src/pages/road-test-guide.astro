---
import BaseLayout from "../layouts/BaseLayout.astro";
import LocationGate from "../components/LocationGate.astro";

const title = 'Road test guide — calm confidence on test day';
const description = 'A practical, low-stress motorcycle road test guide: checklists, common mistakes, and a simple test-day flow.';
const canonicalPath = '/road-test-guide';
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <LocationGate
    targetBasePath={canonicalPath}
    title="Choose your location"
    body={'To show accurate road test information and local resources, please choose your location.'}
    note="Don't see your city? Choose the closest location for now and email support@borrowmybike.ca and we'll add it."
  />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SponsorSlot from "../../components/SponsorSlot.astro";
import { CITIES } from "../../data/cities";

export function getStaticPaths() {
  return CITIES.map((c) => ({
    params: { slug: c.slug },
    props: { city: c },
  }));
}

const { city } = Astro.props;

const cityDisplay = `${city.name}, ${city.province}`;
const canonicalPath = `/cities/${city.slug}`;
const isBC = city.province === "BC";

type CityRow = (typeof CITIES)[number];

const REGION_NEIGHBORS: Record<string, string[]> = {
  // Alberta
  "calgary-area": ["central-ab", "south-ab"],
  "central-ab": ["calgary-area", "edmonton-area", "south-ab"],
  "edmonton-area": ["central-ab", "north-ab"],
  "south-ab": ["calgary-area", "central-ab"],
  "north-ab": ["edmonton-area", "central-ab"],

  // British Columbia
  "lower-mainland": ["fraser-valley"],
  "fraser-valley": ["lower-mainland", "interior-bc"],
  "interior-bc": ["northern-bc", "fraser-valley"],
  "northern-bc": ["interior-bc"],
  "vancouver-island": [],

  // Ontario
  "gta-core": ["gta-west", "gta-east", "hamilton-niagara"],
  "gta-west": ["gta-core", "tri-cities", "hamilton-niagara"],
  "gta-east": ["gta-core", "east-on"],
  "hamilton-niagara": ["gta-west", "gta-core"],
  "tri-cities": ["gta-west", "guelph-area", "southwest-on"],
  "guelph-area": ["tri-cities", "gta-west"],
  "southwest-on": ["tri-cities"],
  "ottawa-area": ["east-on"],
  "east-on": ["ottawa-area", "gta-east"],
  "simcoe-area": ["gta-core"],

  // Quebec
  "montreal-area": ["mauricie", "gatineau-area"],
  "quebec-city-area": ["mauricie"],
  "gatineau-area": ["montreal-area"],
  "eastern-townships": ["montreal-area"],
  "mauricie": ["montreal-area", "quebec-city-area"],

  // Singles / smaller provinces
  "halifax-area": [],
  "moncton-area": ["saint-john-area"],
  "saint-john-area": ["moncton-area"],
  "st-johns-area": [],
  "charlottetown-area": [],
  "yellowknife-area": [],
  "whitehorse-area": [],
  "iqaluit-area": [],
  "winnipeg-area": [],
};

function sortCities(list: CityRow[]) {
  return list.slice().sort((a, b) => {
    const aTier = a.tier ?? 3;
    const bTier = b.tier ?? 3;
    if (aTier !== bTier) return aTier - bTier;
    return a.name.localeCompare(b.name);
  });
}

function buildRelatedCities(current: CityRow) {
  const provinceCities = CITIES.filter(
    (c) => c.province === current.province && c.slug !== current.slug
  );

  const seen = new Set<string>();
  const out: CityRow[] = [];

  const pushList = (list: CityRow[]) => {
    for (const item of sortCities(list)) {
      if (seen.has(item.slug)) continue;
      seen.add(item.slug);
      out.push(item);
      if (out.length >= 8) break;
    }
  };

  const sameRegion = provinceCities.filter(
    (c) => c.region && current.region && c.region === current.region
  );
  pushList(sameRegion);

  const neighborRegions = current.region ? REGION_NEIGHBORS[current.region] ?? [] : [];
  for (const region of neighborRegions) {
    if (out.length >= 8) break;
    const regional = provinceCities.filter((c) => c.region === region);
    pushList(regional);
  }

  if (out.length < 2) {
    const remainingProvinceCities = provinceCities.filter((c) => !seen.has(c.slug));
    pushList(remainingProvinceCities);
  }

  return out.slice(0, 3);
}

const relatedCities = buildRelatedCities(city);

const provinceLabels: Record<string, string> = {
  AB: "Alberta",
  BC: "British Columbia",
  MB: "Manitoba",
  NB: "New Brunswick",
  NL: "Newfoundland and Labrador",
  NS: "Nova Scotia",
  NT: "Northwest Territories",
  NU: "Nunavut",
  ON: "Ontario",
  PE: "Prince Edward Island",
  QC: "Quebec",
  YT: "Yukon",
};

const provinceLabel = provinceLabels[city.province] ?? city.province;
const title = `${city.name} Motorcycle for Class 6 Road Test | ${provinceLabel} Guide | Class6Loaner`;
const description = `Need a motorcycle for your Class 6 road test in ${cityDisplay}? Class6Loaner explains how road-test-ready bike access works, what to bring, and what to expect on test day.`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: `${city.name} Motorcycle for Class 6 Road Test | ${provinceLabel} Guide`,
    description,
    url: `https://class6loaner.com${canonicalPath}`,
    about: [
      "Class 6 road test",
      "motorcycle for road test",
      city.name,
      city.province,
      provinceLabel,
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://class6loaner.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Cities",
        item: "https://class6loaner.com/cities",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: cityDisplay,
        item: `https://class6loaner.com${canonicalPath}`,
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} schema={schema}>
  <section class="card">
    <div class="muted" style="font-weight:900;">{provinceLabel} city guide</div>

    <h1 style="margin:8px 0 0; font-weight:1000;">
      {city.name} motorcycle for Class 6 road test — local guide + next steps
    </h1>

    <p class="muted" style="margin:10px 0 0; max-width:85ch;">
      Need a motorcycle for your Class 6 road test in {cityDisplay}? This page explains what to bring, what happens on test day,
      and how road-test-ready bike access works through BorrowMyBike. The goal is simple: reduce last-minute stress and help you show up prepared.
    </p>

    {isBC ? (
      <div class="card" style="padding:14px; margin-top:12px;">
        <div style="font-weight:1000;">BC note: MST may come before the road test</div>
        <div class="muted" style="margin-top:6px; max-width:90ch;">
          In British Columbia, some riders may need to complete a <strong>Motorcycle Skills Test (MST)</strong> before the road test, depending on their licensing stage. Check ICBC first so you know whether you may need a bike for one appointment or two.
        </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;">
          <a
            class="cta"
            href="https://icbc.com/driver-licensing/types-licences/Get-your-motorcycle-licence"
            target="_blank"
            rel="noopener"
          >
            ICBC motorcycle licensing →
          </a>
          <a
            class="cta"
            href="https://icbc.com/driver-licensing/visit-dl-office/Book-a-road-test"
            target="_blank"
            rel="noopener"
          >
            Book ICBC MST / road test →
          </a>
        </div>
      </div>
    ) : null}

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
      <a
        class="cta"
        href={`https://borrowmybike.ca/browse?city=${encodeURIComponent(city.slug)}&utm_source=class6loaner&utm_medium=website&utm_campaign=canada_launch&utm_content=city_hero_find_bike`}
        rel="noopener"
        target="_blank"
        data-event="book_click"
        data-cta="city_hero"
        data-audience="test_taker"
        data-city={city.slug}
        data-province={city.province}
      >
        Find a mentor + bike →
      </a>
      <a
        class="cta"
        href={`/road-test-guide/${city.slug}`}
        data-event="guide_click"
        data-cta="city_hero"
        data-audience="test_taker"
        data-city={city.slug}
        data-province={city.province}
      >Read the full guide →</a>
      <a
        class="cta"
        href="/become-a-mentor"
        data-event="mentor_click"
        data-cta="city_hero"
        data-audience="mentor"
        data-city={city.slug}
        data-province={city.province}
      >Become a mentor →</a>
    </div>

    <div class="muted" style="margin-top:12px; font-size:13px; max-width:90ch;">
      Need a motorcycle for your Class 6 road test?
      <a href="https://borrowmybike.ca">BorrowMyBike</a> connects you with local mentors who provide a road-test-ready bike.
      Available in and around Calgary, Edmonton, and growing across Alberta and British Columbia.
    </div>
  </section>

  <section class="grid grid-2" style="margin-top:14px;">
    <div class="card">
      <h2 style="margin:0 0 10px; font-weight:1000;">Need a motorcycle for your road test in {city.name}?</h2>

      <p class="muted" style="margin:0 0 10px; max-width:85ch;">
        Many new riders in {city.name} can book a Class 6 test before they have reliable access to a road-test-ready bike.
        BorrowMyBike helps close that gap by connecting test-takers with local mentors who can make test day more predictable.
      </p>

      <p class="muted" style="margin:0 0 10px; max-width:85ch;">
        The booking is for registry road tests only. It is not a recreational ride, an open-ended rental, or a riding lesson.
        Mentors are there to show up prepared, communicate clearly, and help the test day run smoothly.
      </p>

      <div class="card" style="padding:14px; margin-top:10px;">
        <div style="font-weight:1000;">Best fit for test-takers in {city.name}</div>
        <ul style="margin:8px 0 0; padding-left:18px;">
          <li>You already have a road test date or expect to book one soon.</li>
          <li>You have practice riding experience and need a road-test-ready motorcycle.</li>
          <li>You want a structured, accountability-first process instead of last-minute scrambling.</li>
        </ul>
      </div>

      <div style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap;">
        <a class="cta" href={`https://borrowmybike.ca/browse&utm_source=class6loaner&utm_medium=website&utm_campaign=canada_launch&utm_content=city_need_bike`} rel="noopener" target="_blank">
          Browse bikes for {city.name} →
        </a>
        <a class="cta" href="/cities">Browse all city guides →</a>
      </div>

      <h2 style="margin:18px 0 10px; font-weight:1000;">What happens on test day (simple timeline)</h2>

      <ol style="margin:0; padding-left:18px;">
        <li><b>Arrive early</b> so you’re not making rushed decisions under pressure.</li>
        <li><b>Check-in & documents</b> (ID, paperwork, whatever the registry requires).</li>
        <li><b>Bike + gear check</b>: the examiner confirms roadworthiness + safety basics.</li>
        <li><b>Road test</b>: focus on smooth, safe control — not speed or “impressing.”</li>
        <li><b>Wrap-up</b>: results, feedback, and you’re done.</li>
      </ol>

      <h2 style="margin:18px 0 10px; font-weight:1000;">The “don’t panic” checklist</h2>

      <div class="grid" style="grid-template-columns: 1fr; gap:10px;">
        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Bring</div>
          <ul style="margin:8px 0 0; padding-left:18px;">
            <li>Your required ID and registry paperwork</li>
            <li>Any confirmation details for your appointment</li>
            <li>Time buffer (arrive early)</li>
          </ul>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Wear (protective gear)</div>
          <ul style="margin:8px 0 0; padding-left:18px;">
            <li>Proper helmet</li>
            <li>Jacket + gloves</li>
            <li>Long pants</li>
            <li>Closed-toe boots (ideally riding boots)</li>
          </ul>
          <div class="muted" style="margin-top:8px; font-size:13px;">
            If you’re unsure, over-prepare. It’s better than showing up and being turned away.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Mental cues that actually help</div>
          <ul style="margin:8px 0 0; padding-left:18px;">
            <li>Slow breathing before you start</li>
            <li>Ride smooth, not “fast”</li>
            <li>Look where you want to go (head up)</li>
            <li>If you make a small mistake — reset and continue calmly</li>
          </ul>
        </div>
      </div>

      <h2 style="margin:18px 0 10px; font-weight:1000;">Weather & reschedules</h2>

      <p class="muted" style="margin:0; max-width:85ch;">
        Weather can change fast in {city.name}. If the registry reschedules due to conditions, the goal is that nobody gets penalized —
        especially if nobody has checked in yet. Safety &gt; forcing a test.
      </p>

      <div class="card" style="padding:14px; margin-top:10px;">
        <div style="font-weight:1000;">Best practice</div>
        <ul style="margin:8px 0 0; padding-left:18px;">
          <li>If you get a reschedule call/text, communicate early.</li>
          <li>Don’t wait until the last minute if conditions are clearly unsafe.</li>
          <li>Rebook calm. Ride safe.</li>
        </ul>
      </div>

      <h2 style="margin:18px 0 10px; font-weight:1000;">For mentors in {city.name}</h2>

      <p class="muted" style="margin:0; max-width:85ch;">
        Mentors help by making test day calm and predictable. You’re not an instructor, and you’re not coaching during the test.
        Road tests are booked under the assumption the test-taker has already practiced riding.
        Mentors can offer calm reassurance and common-sense coordination through in-app messaging — but no riding lessons, no paid practice sessions, and no last-minute training on test day.
        Mentors are compensated for their time, fuel, and the effort of showing up prepared with a road-test-ready motorcycle.
      </p>

      <div class="grid" style="grid-template-columns: 1fr; gap:10px; margin-top:10px;">
        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">A smart meet-up pattern</div>
          <div class="muted" style="margin-top:6px;">
            Meet about 30 minutes early at the registry. Use that time to confirm documents, gear, and expectations calmly before the test.
            Avoid off-platform practice riding or “training” sessions on test day.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Documents + keys on test day</div>
          <div class="muted" style="margin-top:6px;">
            If the mentor prefers not to hand over papers or keys immediately, they can go into the registry with the test-taker and
            provide documents to staff, or wait by the bike until the examiner comes out for the visual inspection.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">What mentors should NOT do</div>
          <ul style="margin:8px 0 0; padding-left:18px;">
            <li>Argue with examiners or push unsafe choices</li>
            <li>Encourage riding beyond comfort or conditions</li>
            <li>Provide riding lessons or “practice sessions”</li>
            <li>Make promises about outcomes (“you’ll pass”)</li>
          </ul>
        </div>
      </div>

      <h2 style="margin:18px 0 10px; font-weight:1000;">FAQ</h2>

      <div class="grid" style="gap:10px;">
        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">What if the registry refuses the test after inspection?</div>
          <div class="muted" style="margin-top:6px;">
            This can happen for bike-readiness or test-taker readiness reasons. The safest approach is to record the reason calmly and rebook.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">What if weather makes it unsafe?</div>
          <div class="muted" style="margin-top:6px;">
            Don’t force it. If conditions are clearly unsafe or the registry reschedules, prioritize safety and rebook.
            A safe reschedule is always better than a risky test day.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Do mentors teach people how to ride?</div>
          <div class="muted" style="margin-top:6px;">
            No. Mentors provide a road-test-ready motorcycle and a calm, safety-first experience.
            The test-taker should already have riding practice before booking a road test.
          </div>
        </div>
      </div>

      <div class="card" style="padding:14px; margin-top:14px;">
        <div style="font-weight:1000;">Why this {city.name} guide matters</div>
        <div class="muted" style="margin-top:6px;">
          Road-test expectations can vary by province, registry, examiner, weather, and traffic conditions. Use this page as a local preparation guide for {cityDisplay}, then confirm your exact booking details and always follow registry staff and examiner instructions.
        </div>
        <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
          <a class="cta" href="/cities">Browse all city guides →</a>
          <a class="cta" href={`/road-test-guide/${city.slug}`}>Read the full test-taker guide →</a>
        </div>
      </div>

      {relatedCities.length > 0 && (
        <div class="card" style="padding:14px; margin-top:14px;">
          <div style="font-weight:1000;">More {provinceLabel} city guides</div>
          <div class="muted" style="margin-top:6px; max-width:85ch;">
            Explore other motorcycle road-test guides in {provinceLabel}. These internal links help you compare locations and find the most relevant prep information for your area.
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;">
            {relatedCities.map((related) => (
              <a class="cta" href={`/cities/${related.slug}?city=${encodeURIComponent(related.slug)}`}>
                {related.name} →
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="card" style="margin-top:14px; padding:14px;">
        <div style="font-weight:1000;">Ready to move forward?</div>
        <div class="muted" style="margin-top:6px;">
          When you have your test date and time, request a mentor and road-test-ready bike through the app. Keep it simple, show up early, and ride safe.
        </div>
        <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
          <a class="cta" href={`https://borrowmybike.ca/browse&utm_source=class6loaner&utm_medium=website&utm_campaign=canada_launch&utm_content=city_footer_browse`} rel="noopener" target="_blank">Go to BorrowMyBike →</a>
          <a class="cta" href="/become-a-mentor">Become a mentor →</a>
        </div>
      </div>
    </div>

    <div class="grid">
      <SponsorSlot cityName={city.name} slotNumber={1} />
      <SponsorSlot cityName={city.name} slotNumber={2} />
      <SponsorSlot cityName={city.name} slotNumber={3} />
      <SponsorSlot cityName={city.name} slotNumber={4} />
    </div>
  </section>
</BaseLayout>
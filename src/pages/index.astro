---
import BaseLayout from "../layouts/BaseLayout.astro";
import SponsorSlot from "../components/SponsorSlot.astro";
import { groupCitiesByProvince } from "../data/cities";

const title = "Class6Loaner — Safety-first community + calm riding confidence (Canada)";
const description =
  "A Canada-born, safety-first community project: practical guidance for new riders and a clear way for experienced riders to mentor (and get compensated) on test day.";
const canonicalPath = "/";

// Ads are hidden by default. Flip PUBLIC_ADS_ENABLED=true when you have real sponsors.
const ADS_ENABLED = (import.meta.env.PUBLIC_ADS_ENABLED ?? "false") === "true";

// No Saskatchewan for marketing right now
const byProvRaw = groupCitiesByProvince();
delete (byProvRaw as any)["SK"];

const provinces = Object.keys(byProvRaw).sort();

// Keep the embedded data small + safe for the client script
const byProvClient = Object.fromEntries(
  Object.entries(byProvRaw).map(([prov, list]) => [
    prov,
    (list ?? []).map((c) => ({ slug: c.slug, name: c.name, province: c.province })),
  ])
);
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="card">
    <div class="muted" style="font-weight:900;">Calgary pilot • Safety-first • Canada-wide</div>

    <h1 style="margin:8px 0 0; font-weight:1000;">
      Earn $100 supporting a Class 6 road test — within a structured, safety-first process.
    </h1>

    {/* === ADDED: subtle urgency line (home hero) === */}
    <div class="muted" style="margin:8px 0 0; font-weight:800;">
      Calgary pilot launching Spring 2026 — currently onboarding founding mentors.
    </div>

    <p class="muted" style="margin:10px 0 0; max-width:85ch;">
      List your road-test-ready motorcycle. Accept bookings on your schedule. Provide calm coordination and practical test-day guidance. Clear policies. Defined responsibilities. Secure payments.
    </p>

    {/* === ADDED: trust block (directly under hero) === */}
    <div class="card" style="margin-top:14px; padding:14px;">
      <div style="font-weight:1000;">Structured. Transparent. Protected.</div>
      <ul class="muted" style="margin:8px 0 0; padding-left:18px; display:grid; gap:6px;">
        <li>Secure payments and refunds processed through Stripe</li>
        <li>Clear cancellation policies — no surprises</li>
        <li>Clear process if something goes wrong — document and email support (see <a href="https://borrowmybike.ca/legal#damage" rel="noopener" target="_blank" style="font-weight:950; text-decoration: underline;">Damage &amp; responsibility →</a>)</li>
        <li>Deposits discourage no-shows</li>
        <li>Defined responsibilities on both sides</li>
      </ul>
    </div>

    <div class="grid grid-2" style="margin-top:14px; gap:10px;">
      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">You stay in control</div>
        <div class="muted" style="margin-top:6px;">
          Accept or decline any request. No obligation. No subscription. No listing fees.
        </div>
      </div>

      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">Fairness on test day</div>
        <div class="muted" style="margin-top:6px;">
          Deposits discourage no-shows and protect the not-at-fault party if the test can’t proceed due to someone’s fault.
        </div>
      </div>

      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">Payments handled</div>
        <div class="muted" style="margin-top:6px;">
          Payments are handled through Stripe. Booking status is tracked clearly inside the app.
        </div>
      </div>

      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">In-app messaging</div>
        <div class="muted" style="margin-top:6px;">
          In-app messaging is for coordination, clarification, and an opportunity for mentors to pass on valuable experience-based safety tips. Once a booking is accepted, it is confirmed and subject to platform policies.
        </div>
      </div>

      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">Founding mentors</div>
        <div class="muted" style="margin-top:6px;">
          We’re onboarding the first <strong>20 Calgary mentors</strong> now (Calgary pilot).
        </div>
      </div>
    </div>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
<a 
  class="cta"
  data-cta="home_hero"
  data-audience="mentor"
  href="https://borrowmybike.ca/mentors/start?utm_source=class6loaner&utm_medium=website&utm_campaign=calgary_pilot&utm_content=home_hero_mentor"
  rel="noopener"
  target="_blank"
>
  Apply as a Calgary Mentor — Spring Pilot →
</a>
<a 
  class="cta"
  data-cta="home_hero"
  data-audience="test_taker"
  href="https://borrowmybike.ca/test-takers?utm_source=class6loaner&utm_medium=website&utm_campaign=calgary_pilot&utm_content=home_hero_testtaker"
  rel="noopener"
  target="_blank"
>
  Sign up — be first to book this spring →
</a>    
</div>

    <div class="muted" style="margin-top:10px; display:flex; gap:14px; flex-wrap:wrap;">
      <a href="/how-it-works">How it works</a>
      <a href="/become-a-mentor">Mentor overview</a>
      <a href="/mentor-guide">Mentor guide</a>
      <a href="/road-test-guide">Road test guide</a>
      <a href="https://borrowmybike.ca/auth?utm_source=class6loaner&utm_medium=website&utm_campaign=calgary_pilot&utm_content=home_open_app" rel="noopener" target="_blank">Open the app</a>
    </div>

    <div class="grid" style="margin-top:14px; gap:10px;">
      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">Find your city</div>
        <div class="muted" style="margin-top:6px;">
          Choose your location to see local guidance and a calm “test day” checklist.
        </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px;">
          <label style="display:flex; flex-direction:column; gap:6px; font-weight:900; min-width:220px;">
            <span class="muted" style="font-size:13px;">Province</span>
            <select id="prov" class="card" style="padding:10px 12px; border-radius:12px;">
              <option value="">Select a province…</option>
              {provinces.map((p) => <option value={p}>{p}</option>)}
            </select>
          </label>

          <label style="display:flex; flex-direction:column; gap:6px; font-weight:900; min-width:260px;">
            <span class="muted" style="font-size:13px;">City</span>
            <select id="city" class="card" style="padding:10px 12px; border-radius:12px;" disabled>
              <option value="">Select a city…</option>
            </select>
          </label>
        </div>

        <div class="muted" style="margin-top:10px; font-size:13px;">
          Tip: once you pick a city, we keep “city mode” on across pages so the content stays local.
        </div>
      </div>

      <div class="grid grid-3">
        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">For test-takers</div>
          <div class="muted" style="margin-top:6px;">
            Predictable steps. Practical checklists. Less anxiety — more calm confidence.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">For mentors</div>
          <div class="muted" style="margin-top:6px;">
            Show up. Be prepared. Get paid — and help a rider start with a safety-first mindset.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Bookings</div>
          <div class="muted" style="margin-top:6px;">
            When you’re ready to request a mentor + bike, bookings happen on <a href="https://borrowmybike.ca" rel="noopener" target="_blank">BorrowMyBike</a>.ca.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="grid" style="margin-top:14px;">
    <div class="card">
      <h2 style="margin:0 0 10px; font-weight:1000;">Quick answers</h2>
      <p class="muted" style="margin:0 0 12px; max-width:85ch;">Scan the questions. Expand only what you care about.</p>

      <details class="acc">
        <summary>
          <span>Do mentors teach people how to ride?</span>
          <span class="accHint">no lessons</span>
          <span class="accIcon">+</span>
        </summary>
        <div class="accBody">
          <div class="muted" style="max-width:90ch;">
            No. Mentors are not instructors. Road tests are booked assuming the test-taker has already practiced riding. Mentors can share experience-based safety tips and calm coordination through in-app messaging — not lessons or last-minute coaching.
          </div>
        </div>
      </details>

      <details class="acc">
        <summary>
          <span>Insurance & responsibility</span>
          <span class="accHint">know your policy</span>
          <span class="accIcon">+</span>
        </summary>
        <div class="accBody">
          <div class="muted" style="max-width:90ch;">
            <a href="https://borrowmybike.ca" rel="noopener" target="_blank">BorrowMyBike</a> is designed for short, registry-based road tests (not rentals, not lessons). Coverage and permitted use can vary by insurer and province, so both sides should understand their own policies and responsibilities. Full marketplace rules live inside the app.
          </div>
        </div>
      </details>

      <details class="acc">
        <summary>
          <span>Weather & reschedules</span>
          <span class="accHint">safety first</span>
          <span class="accIcon">+</span>
        </summary>
        <div class="accBody">
          <div class="muted" style="max-width:90ch;">
            If conditions are unsafe or the registry reschedules, the goal is a safe rebook under platform rules — not a stressful, last-minute scramble.
          </div>
        </div>
      </details>
    </div>
  </section>

  {ADS_ENABLED ? (
    <section class="grid" style="margin-top:14px;">
      <div class="card">
        <h2 style="margin:0 0 10px; font-weight:1000;">Founding sponsor spots</h2>
        <p class="muted" style="margin:0; max-width:85ch;">
          Canada-wide spots live here. City pages show local sponsor spots once a visitor picks a city.
        </p>
        <div class="grid grid-3" style="margin-top:12px;">
          <SponsorSlot cityName="Canada" slotNumber={1} scope="national" />
          <SponsorSlot cityName="Canada" slotNumber={2} scope="national" />
          <SponsorSlot cityName="Canada" slotNumber={3} scope="national" />
        </div>
      </div>
    </section>
  ) : null}

  <script is:inline data-cities={JSON.stringify(byProvClient)}>
    const byProv = JSON.parse(document.currentScript.dataset.cities);
    const provSel = document.getElementById("prov");
    const citySel = document.getElementById("city");

    if (!provSel || !citySel) {
      console.warn("City selector elements not found.");
    } else {
      function setCityOptions(prov) {
        const list = byProv[prov] || [];
        const options =
          '<option value="">Select a city…</option>' +
          list
            .slice()
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((c) => `<option value="${c.slug}">${c.name}</option>`)
            .join("");

        citySel.innerHTML = options;
        citySel.disabled = list.length === 0;
      }

      // Preselect if saved
      try {
        const savedCity = localStorage.getItem("c6l_city");
        if (savedCity) {
          let foundProv = "";
          for (const p of Object.keys(byProv)) {
            if ((byProv[p] || []).some((c) => c.slug === savedCity)) {
              foundProv = p;
              break;
            }
          }
          if (foundProv) {
            provSel.value = foundProv;
            setCityOptions(foundProv);
            citySel.value = savedCity;
            citySel.disabled = false;
          }
        }
      } catch {}

      provSel.addEventListener("change", () => {
        setCityOptions(provSel.value);
      });

      citySel.addEventListener("change", () => {
        const slug = citySel.value;
        if (!slug) return;
        try {
          localStorage.setItem("c6l_city", slug);
        } catch {}
        window.location.href = `/cities/${slug}?city=` + encodeURIComponent(slug);
      });
    }
  </script>
</BaseLayout>
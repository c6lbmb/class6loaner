---
import BaseLayout from "../layouts/BaseLayout.astro";
import SponsorSlot from "../components/SponsorSlot.astro"; 
import { groupCitiesByProvince } from "../data/cities";

const title = "Class6Loaner — Safety-first Class 6 road-test support (Canada)";
const description =
  "A safety-first, Canada-born community project connecting test-takers with experienced mentors and road-test-ready motorcycles through a structured process. Bookings run on our affiliated site"
const canonicalPath = "/";

// Ads are hidden by default. Flip PUBLIC_ADS_ENABLED=true when you have real sponsors.
const ADS_ENABLED = (import.meta.env.PUBLIC_ADS_ENABLED ?? "false") === "true";

// ===== Launch control =====
// Keep the national framing, but only enable certain provinces/cities until you open wider.
// To expand later, just add province codes here (e.g., "BC", "ON") and remove city limits if desired.
const ENABLED_PROVINCES = ["AB"];

// If you want to limit to specific cities during the pilot, list slugs per province here.
// (Leave a province out to allow all its cities once enabled.)
const ENABLED_CITY_SLUGS: Record<string, string[]> = {
  AB: ["calgary"],
};

const byProvRaw = groupCitiesByProvince();
const provincesAll = Object.keys(byProvRaw).sort();

// Keep the embedded data small + safe for the client script
const byProvClient = Object.fromEntries(
  Object.entries(byProvRaw).map(([prov, list]) => [
    prov,
    (list ?? []).map((c) => ({ slug: c.slug, name: c.name, province: c.province })),
  ])
);
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="card">
    <!-- HERO (match BMB visual direction) -->
    <div
      class="card"
      style="
        padding: 0;
        overflow: hidden;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
      "
    >
      <div
        style="
          position: relative;
          min-height: 360px;
          background-image: url('/images/hero-bike.jpeg');
          background-size: cover;
          background-position: center;
        "
      >
        <div
          style="
            position:absolute;
            inset:0;
            background: linear-gradient(90deg, rgba(11,31,59,.62), rgba(11,31,59,.35), rgba(11,31,59,.10));
          "
        ></div>

        <div style="position:relative; padding: 18px;">
          <div class="muted" style="font-weight:1000; color: rgba(255,255,255,.88);">
            Canada-wide vision • Safety-first • Structured process
          </div>

          <h1 style="margin:10px 0 0; font-weight:1000; color:white; max-width: 26ch;">
            Structured Class 6 road-test support — across Canada.
          </h1>

          <p style="margin:10px 0 0; color: rgba(255,255,255,.90); max-width: 70ch; font-weight: 650;">
            Connect with an experienced local mentor and a road-test-ready motorcycle through a clear, accountability-first process.
            Bookings run on BorrowMyBike.ca.
          </p>

         

          <div style="margin-top:10px; color: rgba(255,255,255,.82); font-size: 13px; font-weight: 800;">
            Pilot availability: <span style="color:white;">Calgary, Alberta</span>. Opening additional cities and provinces soon.
          </div>

          <div style="margin-top:115px; color: rgba(255,255,255,.82); font-size: 13px; font-weight: 800;">
            Secure Payment Processing through: <span style="color:white;">Stripe</span>. 
          </div>
        </div>
      </div>
    </div>

 <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
            <a
              class="cta"
              data-cta="home_hero"
              data-audience="mentor"
              href="https://borrowmybike.ca/mentors/start?utm_source=class6loaner&utm_medium=website&utm_campaign=canada_launch&utm_content=home_hero_mentor"
              rel="noopener"
              target="_blank"
            >Become a Mentor →</a>

            <a
              class="cta"
              data-cta="home_hero"
              data-audience="test_taker"
              href="https://borrowmybike.ca/test-takers?utm_source=class6loaner&utm_medium=website&utm_campaign=canada_launch&utm_content=home_hero_testtaker"
              rel="noopener"
              target="_blank"
            >Find a Mentor + Bike →</a>
          </div>

    <!-- LOCATION SELECT -->
    <div class="grid" style="margin-top:14px; gap:10px;">
      <div class="card" style="padding:14px;">
        <div style="font-weight:1000;">Choose your province and city</div>
        <div class="muted" style="margin-top:6px; max-width: 90ch;">
          Select your province and city to see information for your local registry area.     
         </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px;">
          <label style="display:flex; flex-direction:column; gap:6px; font-weight:900; min-width:220px;">
            <span class="muted" style="font-size:13px;">Province</span>
            <select id="prov" class="card" style="padding:10px 12px; border-radius:12px;">
              <option value="">Select a province…</option>
              {provincesAll.map((p) => (
                <option value={p} disabled={!ENABLED_PROVINCES.includes(p)}>
                  {p}{ENABLED_PROVINCES.includes(p) ? "" : " (opening soon)"}
                </option>
              ))}
            </select>
          </label>

          <label style="display:flex; flex-direction:column; gap:6px; font-weight:900; min-width:260px;">
            <span class="muted" style="font-size:13px;">City</span>
            <select id="city" class="card" style="padding:10px 12px; border-radius:12px;" disabled>
              <option value="">Select a city…</option>
            </select>
          </label>
        </div>

        <div class="muted" style="margin-top:10px; font-size:13px;">
          Tip: once you pick a city, we keep your location saved so guides and information stay relevant to your area.
        </div>
      </div>

      <div class="grid grid-3">
        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">For test-takers</div>
          <div class="muted" style="margin-top:6px;">
            Clear steps, checklists, and less uncertainty before test day.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">For mentors</div>
          <div class="muted" style="margin-top:6px;">
            Mentors earn <strong>$100</strong> per completed booking and help new riders start with a safety-first mindset.
          </div>
        </div>

        <div class="card" style="padding:14px;">
          <div style="font-weight:1000;">Bookings</div>
          <div class="muted" style="margin-top:6px;">
            All booking, payments, and rules are handled inside <a href="https://borrowmybike.ca" rel="noopener" target="_blank">BorrowMyBike</a>.ca.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT (short) -->
  <section class="grid" style="margin-top:14px;">
    <div class="card">
      <h2 style="margin:0 0 10px; font-weight:1000;">Why this exists</h2>

      <p class="muted" style="margin:0 0 10px; max-width:90ch;">
        Across Canada, many new riders face two practical problems: <strong>limited road test appointment availability</strong> and
        <strong>limited access to a road-test-ready motorcycle</strong>. Some registries offer rentals, but availability can be inconsistent.
      </p>

      <p class="muted" style="margin:0; max-width:90ch;">
        What started as helping riders bridge that gap evolved into a structured mentorship-first process. The goal isn’t just passing a test —
        it’s building calm confidence and a safety-first mindset that carries into a rider’s first season.
      </p>

      <div class="muted" style="margin-top:10px; display:flex; gap:14px; flex-wrap:wrap;">
        <a href="/about">Read the full story →</a>
        <a href="/how-it-works">How it works →</a>
        <a href="https://borrowmybike.ca/legal#damage" rel="noopener" target="_blank">Damage &amp; responsibility →</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="grid" style="margin-top:14px;">
    <div class="card">
      <h2 style="margin:0 0 10px; font-weight:1000;">FAQ (mentors + test-takers)</h2>
      <p class="muted" style="margin:0 0 12px; max-width:90ch;">
        Expand to see answers. We keep it structured so both sides know what they’re agreeing to.
      </p>

      <details class="bmb-acc">
        <summary>
          <span>Is this an open rental / joyride marketplace?</span>
         
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            No. This is built for short, registry-based Class 6 road tests. It is not designed for recreational rentals, lessons, or long rides.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>Do mentors teach people how to ride?</span>
         
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            No. Mentors are not instructors. They can share experience-based safety tips and calm coordination through messaging — not lessons or last‑minute coaching.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>What do mentors earn?</span>
          
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            Mentors earn <strong>$100</strong> for a completed booking. Details and payouts are handled inside <a href="https://borrowmybike.ca" target="_blank" rel="noopener noreferrer">BorrowMyBike.ca</a>.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>What about deposits and no-shows?</span>
         
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            Deposits are used for accountability and to discourage no‑shows. If the road test can’t proceed due to one party’s fault, platform rules determine forfeiture and any credit due to the not‑at‑fault party.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>What if the bike gets damaged?</span>
         
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            Responsibility depends on fault and the terms accepted at checkout. Both sides should understand their own insurance coverage. See the full damage section on <a href="https://borrowmybike.ca" target="_blank" rel="noopener noreferrer">BorrowMyBike.ca</a>:
            <a href="https://borrowmybike.ca/legal#damage" rel="noopener" target="_blank">Damage &amp; responsibility →</a>
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>How do cancellations work?</span>
          
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            Once a booking is accepted, it’s confirmed and subject to platform policies. Cancellation outcomes depend on timing and fault scenarios. Full rules live in the app.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>What if the examiner cancels or weather is unsafe?</span>
         
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            If a test is rescheduled by the registry or conditions are unsafe, the goal is a safe rebook under platform rules — not a stressful last‑minute scramble.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
  <summary>
    <span>Can I take an Alberta Class 6 road test on an automatic motorcycle?</span>
  </summary>
  <div class="bmb-accBody">
    <div class="muted" style="max-width:95ch;">
      Yes. Alberta’s Class 6 information does not list an automatic-transmission restriction for a standard Class 6 road test. The separate restriction Alberta does call out is for <strong>3-wheeled motorcycles</strong>.
    </div>
  </div>
</details>

<details class="bmb-acc">
  <summary>
    <span>Can I use a 50cc scooter or moped for a Class 6 road test?</span>
  </summary>
  <div class="bmb-accBody">
    <div class="muted" style="max-width:95ch;">
      No. In Alberta, vehicles with an engine displacement of <strong>not more than 50cc</strong> fall into the moped category. For practical Class 6 road-test purposes, the safer rule is: <strong>50cc and under is not suitable for a full motorcycle road test; 51cc and up is the motorcycle category you should plan around.</strong>
    </div>
  </div>
</details>

<details class="bmb-acc">
  <summary>
    <span>What happens if I take my road test on a 3-wheeled motorcycle?</span>
  </summary>
  <div class="bmb-accBody">
    <div class="muted" style="max-width:95ch;">
      In Alberta, if you take your Class 6 road test on a <strong>3-wheeled motorcycle</strong>, your licence will be restricted to operating <strong>3-wheeled motorcycles only</strong>.
    </div>
  </div>
</details>

<details class="bmb-acc">
  <summary>
    <span>How early should I arrive for my road test?</span>
  </summary>
  <div class="bmb-accBody">
    <div class="muted" style="max-width:95ch;">
      Plan to arrive <strong>30 minutes early</strong> unless your registry tells you otherwise. That gives you time for check-in, documents, and any last-minute instructions without adding stress.
    </div>
  </div>
</details>

      <details class="bmb-acc">
        <summary>
          <span>How are payments handled?</span>
          
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            Payments and refunds are processed through Stripe. Booking status and outcomes are tracked inside the app.
          </div>
        </div>
      </details>

      <details class="bmb-acc">
        <summary>
          <span>Do I have to accept every request as a mentor?</span>
          
        </summary>
        <div class="bmb-accBody">
          <div class="muted" style="max-width:95ch;">
            No. Mentors can accept or decline requests. There’s no subscription and no obligation to accept.
          </div>
        </div>
      </details>
    </div>
  </section>

  {ADS_ENABLED ? (
    <section class="grid" style="margin-top:14px;">
      <div class="card">
        <h2 style="margin:0 0 10px; font-weight:1000;">Founding sponsor spots</h2>
        <p class="muted" style="margin:0; max-width:85ch;">
          Canada-wide spots live here. City pages show local sponsor spots once a visitor picks a city.
        </p>
        <div class="grid grid-3" style="margin-top:12px;">
          <SponsorSlot cityName="Canada" slotNumber={1} scope="national" />
          <SponsorSlot cityName="Canada" slotNumber={2} scope="national" />
          <SponsorSlot cityName="Canada" slotNumber={3} scope="national" />
        </div>
      </div>
    </section>
  ) : null}

  <script is:inline data-cities={JSON.stringify(byProvClient)} data-enabled-provs={JSON.stringify(ENABLED_PROVINCES)} data-enabled-cities={JSON.stringify(ENABLED_CITY_SLUGS)}>
    const byProv = JSON.parse(document.currentScript.dataset.cities);
    const enabledProvs = JSON.parse(document.currentScript.dataset.enabledProvs || "[]");
    const enabledCitySlugs = JSON.parse(document.currentScript.dataset.enabledCities || "{}");

    const provSel = document.getElementById("prov");
    const citySel = document.getElementById("city");

    if (!provSel || !citySel) {
      console.warn("City selector elements not found.");
    } else {
      function setCityOptions(prov) {
        const list = (byProv[prov] || []).slice();
        const allowList = enabledCitySlugs[prov];

        const filtered = Array.isArray(allowList) && allowList.length
          ? list.filter((c) => allowList.includes(c.slug))
          : list;

        const options =
          '<option value="">Select a city…</option>' +
          filtered
            .slice()
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((c) => `<option value="${c.slug}">${c.name}</option>`)
            .join("");

        citySel.innerHTML = options;
        citySel.disabled = filtered.length === 0;
      }

      // If someone loads a city directly, keep things consistent
      try {
        const savedCity = localStorage.getItem("c6l_city");
        if (savedCity) {
          let foundProv = "";
          for (const p of Object.keys(byProv)) {
            if ((byProv[p] || []).some((c) => c.slug === savedCity)) {
              foundProv = p;
              break;
            }
          }

          // If the saved city isn't currently enabled, don't force-select it.
          const allowList = enabledCitySlugs[foundProv];
          const isEnabledCity =
            enabledProvs.includes(foundProv) &&
            (Array.isArray(allowList) && allowList.length ? allowList.includes(savedCity) : true);

          if (foundProv && isEnabledCity) {
            provSel.value = foundProv;
            setCityOptions(foundProv);
            citySel.value = savedCity;
            citySel.disabled = false;
          }
        }
      } catch {}

      provSel.addEventListener("change", () => {
        const p = provSel.value;
        if (!p || !enabledProvs.includes(p)) {
          citySel.innerHTML = '<option value="">Select a city…</option>';
          citySel.disabled = true;
          return;
        }
        setCityOptions(p);
      });

      citySel.addEventListener("change", () => {
        const slug = citySel.value;
        if (!slug) return;
        try {
          localStorage.setItem("c6l_city", slug);
        } catch {}
        window.location.href = `/cities/${slug}?city=` + encodeURIComponent(slug);
      });
    }

    // OPTIONAL: pass city into BMB links once city mode is on
    (function () {
      try {
        const city = localStorage.getItem("c6l_city");
        if (!city) return;

        document.querySelectorAll('a[href^="https://borrowmybike.ca"]').forEach((a) => {
          const href = a.getAttribute("href") || "";
          if (!href || href.includes("city=")) return;
          a.setAttribute("href", href + (href.includes("?") ? "&" : "?") + "city=" + encodeURIComponent(city));
        });
      } catch {}
    })();
  </script>
</BaseLayout>

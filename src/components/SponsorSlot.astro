---
type Props = {
  cityName?: string;
  slotNumber: number;

  // local or national sponsor
  scope?: "local" | "national";

  // premium or standard slot
  tier?: "premium" | "standard";

  // top, mid, bottom placement
  placement?: "top" | "mid" | "bottom";

  // tighter layout if needed
  compact?: boolean;
};

const {
  cityName = "Your city",
  slotNumber,
  scope = "local",
  tier = "standard",
  placement = "bottom",
  compact = false,
} = Astro.props;

// Global kill-switch
const ADS_ENABLED = (import.meta.env.PUBLIC_ADS_ENABLED ?? "false") === "true";

if (!ADS_ENABLED) {
  return null;
}

const isNational = scope === "national";
const isPremium = tier === "premium";

const title = isNational
  ? "Founding national partner opportunity"
  : `Founding partner opportunity — ${cityName}`;

const subtitle = isNational
  ? "We're highlighting a small number of trusted businesses as Class6Loaner expands across Canada."
  : `We're highlighting a small number of trusted local businesses as we launch in ${cityName}.`;

const showEmailLine = !compact;

const borderColor = isPremium ? "#f59e0b" : "#e5e7eb";
const background = isPremium ? "#fff7ed" : "#fff";
---

<div class="card" style={`padding:14px; border:1px solid ${borderColor}; background:${background};`}>
  <div style="font-weight:1000;">
    {title}
  </div>

  <div class="muted" style="margin-top:6px;">
    {subtitle}
  </div>

  {showEmailLine && (
    <div class="muted" style="margin-top:10px;">
      Interested in this placement?{" "}
      <a href="mailto:support@borrowmybike.ca">
        support@borrowmybike.ca
      </a>
    </div>
  )}
</div>
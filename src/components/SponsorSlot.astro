---
import { getSponsorAd } from "../data/sponsorAds";

type Props = {
  cityName?: string;
  slotNumber: number;
  scope?: "local" | "national";
  tier?: "premium" | "standard";
  placement?: "top" | "mid" | "bottom";
  compact?: boolean;
};

const {
  slotNumber,
  scope = "local",
  tier = "standard",
  placement = "bottom",
  compact = false,
} = Astro.props;

const ADS_ENABLED = (import.meta.env.PUBLIC_ADS_ENABLED ?? "false") === "true";

if (!ADS_ENABLED) {
  return null;
}

const isPremium = tier === "premium";
const selectedAd = getSponsorAd({ placement, scope, slotNumber });
const borderColor = isPremium ? selectedAd.accent : "transparent";
---

<a
  href={selectedAd.href}
  rel="noopener"
  target={selectedAd.href.startsWith("mailto:") ? undefined : "_blank"}
  class="sponsor-ad"
  style={`
    position:relative;
    display:block;
    min-height:${compact ? "118px" : "145px"};
    overflow:hidden;
    border-radius:0;
    border:1px solid ${borderColor};
    background:${selectedAd.bg};
    color:white;
    text-decoration:none;
    box-shadow:0 10px 26px rgba(15,23,42,.16);
  `}
>
  <img
    src={selectedAd.image}
    alt=""
    loading="lazy"
    style="
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      object-fit:cover;
      object-position:center right;
      opacity:.58;
      filter:saturate(1.05) contrast(1.05) brightness(1.08);
    "
  />

  <div
    style="
      position:absolute;
      inset:0;
      background:linear-gradient(90deg, rgba(11,31,59,.62) 0%, rgba(11,31,59,.36) 55%, rgba(11,31,59,.08) 100%);
    "
  ></div>

  <div
    style={`
      position:relative;
      z-index:1;
      padding:${compact ? "14px" : "18px 20px"};
      display:flex;
      flex-direction:column;
      justify-content:center;
      min-height:${compact ? "118px" : "145px"};
      max-width:720px;
    `}
  >
    {selectedAd.logo ? (
      <img
        src={selectedAd.logo}
        alt={selectedAd.eyebrow}
        style="
          width:138px;
          max-width:42%;
          height:auto;
          margin-bottom:8px;
          display:block;
        "
      />
    ) : (
      <div style="font-size:11px; font-weight:1000; letter-spacing:.12em; text-transform:uppercase; color:rgba(255,255,255,.86); margin-bottom:8px;">
        {selectedAd.eyebrow}
      </div>
    )}

    <div
      style="
        font-size:clamp(21px, 2.7vw, 34px);
        line-height:1.02;
        font-weight:1000;
        letter-spacing:-.035em;
        max-width:620px;
      "
    >
      {selectedAd.headlineTop} {selectedAd.headlineMain}
    </div>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px;">
      {selectedAd.bodyLines.map((line) => (
        <span style="display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:900; color:rgba(255,255,255,.86);">
          <span style={`color:${selectedAd.accent};`}>➤</span>
          {line}
        </span>
      ))}
    </div>

    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-top:12px;">
      <span
        style={`
          display:inline-flex;
          align-items:center;
          justify-content:center;
          padding:8px 13px;
          border-radius:999px;
          background:${selectedAd.buttonBg};
          color:${selectedAd.buttonText};
          font-size:13px;
          font-weight:1000;
          box-shadow:0 8px 18px rgba(0,0,0,.20);
        `}
      >
        {selectedAd.cta} →
      </span>

      <span style="font-size:11px; font-weight:850; color:rgba(255,255,255,.64);">
        {selectedAd.key === "sponsor" ? "Premium placement available" : "via Class6Loaner"}
      </span>
    </div>
  </div>
</a>